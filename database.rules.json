{
  "rules": {
    ".read": true,
    ".write": false,

    "rooms": {
      "$roomId": {
        ".read": true,

        "name": {
          ".write": "auth != null && (!data.exists() || root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid)",
          ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 30"
        },
        "ownerId": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid)",
          ".validate": "newData.isString() && (newData.val() === auth.uid || ($roomId === 'lobby' && newData.val() === 'system'))"
        },
        "ownerName": {
          ".write": "auth != null && root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "createdAt": {
          ".write": "auth != null && !data.exists()",
          ".validate": "newData.val() == now"
        },

        "messages": {
          ".write": "auth != null && $roomId === 'lobby'",
          "$msgId": {
            ".write": "auth != null && (root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid || root.child('rooms/'+$roomId+'/members/'+auth.uid).exists() || $roomId === 'lobby') && !root.child('rooms/'+$roomId+'/banned/'+auth.uid).exists() && !root.child('rooms/'+$roomId+'/kicked/'+auth.uid).exists()",
            ".validate": "newData.hasChildren(['userId','username','text','timestamp']) && newData.child('userId').val() === auth.uid",
            "userId":    { ".validate": "newData.val() === auth.uid" },
            "username":  { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
            "text":      { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
            "timestamp": { ".validate": "newData.val() == now" },
            "$other":    { ".validate": false }
          }
        },

        "members": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid && (!newData.exists() || $roomId === 'lobby' || root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid || root.child('invites/'+auth.uid+'/'+$roomId).exists() || data.exists()) && !root.child('rooms/'+$roomId+'/banned/'+auth.uid).exists() && !root.child('rooms/'+$roomId+'/kicked/'+auth.uid).exists()",
            "name":     { ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 30" },
            "joinedAt": { ".validate": "newData.val() == now || newData.isNumber()" },
            "$other":   { ".validate": false }
          }
        },

        "kicked": {
          ".read": true,
          "$uid": {
            ".write": "auth != null && (root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid || ($uid === auth.uid && !newData.exists()))",
            ".validate": "newData.isBoolean() || !newData.exists()"
          }
        },

        "banned": {
          ".read": true,
          "$uid": {
            ".write": "auth != null && root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid",
            ".validate": "newData.hasChildren() || !newData.exists()",
            "name":     { ".validate": "newData.isString() && newData.val().length <= 30" },
            "bannedAt": { ".validate": "newData.isNumber()" },
            "$other":   { ".validate": false }
          }
        },

        ".write": "auth != null && !data.exists() && (newData.child('ownerId').val() === auth.uid || ($roomId === 'lobby' && newData.child('ownerId').val() === 'system'))",
        ".validate": "newData.hasChildren(['name','ownerId','createdAt']) || data.exists()"
      }
    },

    "invites": {
      "$targetUid": {
        ".read": "auth != null && $targetUid === auth.uid",
        "$roomId": {
          ".read": "auth != null && ($targetUid === auth.uid || root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid)",
          ".write": "auth != null && (root.child('rooms/'+$roomId+'/ownerId').val() === auth.uid || ($targetUid === auth.uid && !newData.exists()))",
          ".validate": "newData.hasChildren(['fromName','roomName']) || !newData.exists()",
          "from":      { ".validate": "newData.isString() && newData.val() === root.child('rooms/'+$roomId+'/ownerId').val()" },
          "fromName":  { ".validate": "newData.isString() && newData.val().length <= 30" },
          "roomId":    { ".validate": "newData.isString() && newData.val() === $roomId" },
          "roomName":  { ".validate": "newData.isString() && newData.val().length <= 30" },
          "timestamp": { ".validate": "newData.isNumber()" },
          "ts":        { ".validate": "newData.isNumber() || newData.val() == now" },
          "$other":    { ".validate": false }
        }
      }
    },

    "horns": {
      "$uid": {
        ".read": true,
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['from','ts']) || !newData.exists()",
        "from": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "ts":   { ".validate": "newData.isNumber() && newData.val() > now - 5000 && newData.val() < now + 5000" },
        "$other": { ".validate": false }
      }
    },

    "bans": {
      ".read": true,
      "users": {
        "$uid": { ".write": "auth != null && $uid === auth.uid" }
      },
      "ips": {
        "$ip":  { ".write": "auth != null" }
      }
    },

    "meta": {
      ".read": true,
      "lastCleanup": {
        ".write": "auth != null",
        ".validate": "newData.isNumber()"
      }
    },

    "hallOfFame": {
      ".read": true,
      "$gameId": {
        "$uid": {
          ".write": "auth != null && $uid === auth.uid",
          ".validate": "newData.hasChildren(['name','score']) || !newData.exists()",
          "name":      { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
          "score":     { ".validate": "newData.isNumber()" },
          "meta":      { ".validate": true },
          "updatedAt": { ".validate": "newData.isNumber() || newData.val() == now" },
          "$other":    { ".validate": false }
        }
      }
    }
  }
}
