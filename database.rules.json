{
  "rules": {
    ".read": true,
    ".write": false,

    "rooms": {
      "$roomId": {
        ".read": true,

        "name": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 30"
        },
        "ownerId": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 64"
        },
        "ownerName": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "createdAt": {
          ".write": true,
          ".validate": "newData.val() == now || newData.isNumber()"
        },

        "messages": {
          ".write": true,
          "$msgId": {
            ".validate": "newData.hasChildren(['userId','username','text','timestamp']) && ($roomId === 'lobby' || root.child('rooms/'+$roomId+'/members/'+newData.child('userId').val()).exists()) && !root.child('rooms/'+$roomId+'/banned/'+newData.child('userId').val()).exists() && !root.child('rooms/'+$roomId+'/kicked/'+newData.child('userId').val()).exists()",
            "userId":    { ".validate": "newData.isString() && newData.val().length <= 64" },
            "username":  { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
            "text":      { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500" },
            "timestamp": { ".validate": "newData.val() == now" },
            "$other":    { ".validate": false }
          }
        },

        "members": {
          ".write": true,
          "$uid": {
            "name":     { ".validate": "newData.isString() && newData.val().length >= 2 && newData.val().length <= 30" },
            "joinedAt": { ".validate": "newData.val() == now || newData.isNumber()" },
            "$other":   { ".validate": false }
          }
        },

        "kicked": {
          ".write": true,
          "$uid": { ".validate": "newData.isBoolean() || !newData.exists()" }
        },

        "banned": {
          ".write": true,
          "$uid": {
            ".validate": "newData.hasChildren() || !newData.exists()",
            "name":     { ".validate": "newData.isString() && newData.val().length <= 30" },
            "bannedAt": { ".validate": "newData.isNumber()" },
            "$other":   { ".validate": false }
          }
        },

        ".write": true
      }
    },

    "invites": {
      "$targetUid": {
        ".read": true,
        "$roomId": {
          ".write": true,
          ".validate": "newData.hasChildren(['fromName','roomName']) || !newData.exists()",
          "from":      { ".validate": "newData.isString() && newData.val().length <= 64" },
          "fromName":  { ".validate": "newData.isString() && newData.val().length <= 30" },
          "roomId":    { ".validate": "newData.isString() && newData.val() === $roomId" },
          "roomName":  { ".validate": "newData.isString() && newData.val().length <= 30" },
          "timestamp": { ".validate": "newData.isNumber()" },
          "ts":        { ".validate": "newData.isNumber() || newData.val() == now" },
          "$other":    { ".validate": false }
        }
      }
    },

    "horns": {
      "$uid": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['from','ts']) || !newData.exists()",
        "from": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "ts":   { ".validate": "newData.isNumber() && newData.val() > now - 60000 && newData.val() < now + 60000" },
        "$other": { ".validate": false }
      }
    },

    "bans": {
      ".read": true,
      ".write": true
    },

    "meta": {
      ".read": true,
      ".write": true,
      "lastCleanup": { ".validate": "newData.isNumber()" }
    },

    "hallOfFame": {
      ".read": true,
      "$gameId": {
        "$uid": {
          ".write": true,
          ".validate": "newData.hasChildren(['name','score']) || !newData.exists()",
          "name":      { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
          "score":     { ".validate": "newData.isNumber()" },
          "meta":      { ".validate": true },
          "updatedAt": { ".validate": "newData.isNumber() || newData.val() == now" },
          "$other":    { ".validate": false }
        }
      }
    }
  }
}
